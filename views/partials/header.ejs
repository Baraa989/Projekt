<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Freaky Fashion</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <header class="site-header">
        <div class="container header-container">
            <div class="logo">
                <a href="/"><img src="https://docs.pingidentity.com/connectors/_images/connector-logos/google-hires-logo.png" alt="Freaky Fashion" class="logo-img"></a>
            </div>
            <div class="header-bottom">
                <div class="header-search">
                    <form action="/search.html" method="GET">
                        <input class="search-input" name="q" type="search" placeholder="Sök produkt" value="<%= typeof query !== 'undefined' ? query : '' %>">
                    </form>
                </div>
                <div class="header-icons">
                    <a href="#"><i class="bi bi-heart-fill"></i></a>
                    <a href="/checkout.html"><i class="bi bi-basket2-fill"></i></a>
                </div>
            </div>
        </div>
        <nav class="main-nav">
            <div class="container nav-container">
                <ul>
                    <% categories.forEach(cat => { %>
                    <li><a href="#"><%= cat.name %></a></li>
                    <% }) %>
                </ul>
            </div>
        </nav>
    </header>