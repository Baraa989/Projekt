<%- include('partials/header') %>

<main class="container">
    <section id="product-content" class="product-details">
        <div class="product-details-img">
            <div class="product-details-img-placeholder" style="background-image: url('<%= product.image_url %>'); background-size: cover; background-position: center;"></div>
        </div>
        <div class="product-details-info">
            <h2><%= product.name %></h2>
            <p class="brand text-muted"><%= product.brand || '' %></p>
            <p><%= product.description || '' %></p>
            <p class="price"><%= product.price %> SEK</p>
            <button class="btn btn-primary">Lägg i varukorg</button>
            
            <div class="pd-usp mt-4">
                <div class="usp-item"><i class="bi bi-globe"></i> Gratis frakt och returer</div>
                <div class="usp-item"><i class="bi bi-airplane"></i> Expressfrakt</div>
                <div class="usp-item"><i class="bi bi-shield-check"></i> Säkra betalningar</div>
                <div class="usp-item"><i class="bi bi-emoji-smile"></i> Nyheter varje dag</div>
            </div>
        </div>
    </section>

    <section class="related-products mt-5">
        <h3>Liknande produkter</h3>
        <div id="related-grid" class="related-grid">
            <% related.forEach(p => { %>
                <%- include('partials/product-card', { product: p }) %>
            <% }) %>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
